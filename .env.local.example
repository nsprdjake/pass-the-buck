NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web Push — public VAPID key. Safe to commit. Private half lives only
# in the Supabase edge function's secrets (VAPID_PRIVATE_KEY).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# OpenAI — server-side only (NOT prefixed NEXT_PUBLIC_, so it never
# ships to the browser). Required for the AI avatar generator at
# /api/avatars/generate. Without it the route returns a clean 503 and
# the rest of the app works fine.
#
# Get a key: https://platform.openai.com/api-keys
# Note: gpt-image-1 requires a verified org. Visit
# https://platform.openai.com/settings/organization/general and click
# "Verify Organization" if you see a 403 on first generation.
OPENAI_API_KEY=sk-your-openai-key
